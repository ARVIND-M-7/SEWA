# ══════════════════════════════════════════════════════════════
# SEWA — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Environment / Secrets ─────────────────────────────────────
# ⚠️  NEVER commit .env files — they contain secrets!
.env
.env.local
.env.production
.env.*.local
sewa_final/.env
SEWA-frontend/.env

# Templates are safe to commit
!.env.example
!sewa_final/.env.example
!SEWA-frontend/.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/
env/
ENV/

# ── Database ──────────────────────────────────────────────────
# SQLite database file (contains patient data — never commit)
*.db
*.sqlite
*.sqlite3
sewa_final/sewa.db

# ── ML Models ─────────────────────────────────────────────────
# Uncomment if you don't want to track large model files in git
# sewa_final/models/*.pkl
# sewa_final/models/*.joblib

# ── Node / Frontend ───────────────────────────────────────────
SEWA-frontend/node_modules
SEWA-frontend/dist/
SEWA-frontend/build/
SEWA-frontend/.pnp
SEWA-frontend/.pnp.js

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / OS ───────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# ── Testing / Coverage ────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints